<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="#FFFFFFFF" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="#FFE5E7EB" />
        </shape>
    </item>
    <item
        android:bottom="0dp"
        android:left="0dp"
        android:right="0dp"
        android:top="0dp">
        <ripple android:color="#1A4F46E5">
            <item android:id="@android:id/mask">
                <shape>
                    <solid android:color="#FFFFFFFF" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
        </ripple>
    </item>
</layer-list>
