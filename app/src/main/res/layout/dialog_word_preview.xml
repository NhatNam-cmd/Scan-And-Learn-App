<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp"
    android:background="@android:color/white">

    <TextView
        android:id="@+id/tv_word"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="hello"
        android:textColor="@android:color/black"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_play_audio" />

    <ImageButton
        android:id="@+id/btn_play_audio"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_media_play"
        android:contentDescription="Play Audio"
        app:layout_constraintTop_toTopOf="@id/tv_word"
        app:layout_constraintBottom_toBottomOf="@id/tv_word"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_phonetic"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="/həˈləʊ/"
        android:textColor="#757575"
        android:textSize="16sp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_word"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_definition"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="used as a greeting or to begin a telephone conversation."
        android:textColor="@android:color/black"
        android:textSize="16sp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_phonetic"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_add_to_vocabulary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add to Vocabulary"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_definition"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
