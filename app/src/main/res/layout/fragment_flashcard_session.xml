<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground">

    <!-- ===== TOP BAR: Progress + nút thoát ===== -->
    <LinearLayout
        android:id="@+id/layout_topbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Nút đóng -->
        <TextView
            android:id="@+id/btn_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_detail_section"
            android:gravity="center"
            android:text="✕"
            android:textColor="?colorOnBackground"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Progress bar + label -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_progress_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="?colorOnBackground"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_score_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?colorOnSurface"
                    android:textSize="12sp" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progress_session"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="6dp"
                android:max="100"
                android:progressDrawable="@drawable/progress_vocabulary_mastery" />
        </LinearLayout>

        <!-- Badge tổng từ -->
        <TextView
            android:id="@+id/tv_total_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_vocabulary_stat"
            android:gravity="center"
            android:minWidth="44dp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ===== FLASHCARD: Thẻ lật ===== -->
    <!-- Mặt trước (FRONT) — chỉ hiện từ + phiên âm -->
    <FrameLayout
        android:id="@+id/card_front"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_vocabulary_header"
        app:layout_constraintBottom_toTopOf="@id/layout_hint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_topbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <TextView
                android:id="@+id/tv_card_front_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_vocabulary_stat"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:text="TỪ VỰNG"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_card_word"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:textColor="#FFFFFFFF"
                android:textSize="42sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_card_phonetic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:textColor="#DFFFFFFF"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tv_card_source"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textColor="#99FFFFFF"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:alpha="0.7"
                android:gravity="center"
                android:text="👆 Nhấn để xem nghĩa"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Mặt sau (BACK) — hiện nghĩa + ví dụ + ghi chú — ẩn ban đầu -->
    <FrameLayout
        android:id="@+id/card_back"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_flashcard_card"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/layout_hint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_topbar">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="28dp">

                <!-- Từ nhỏ ở mặt sau để nhớ ngữ cảnh -->
                <TextView
                    android:id="@+id/tv_back_word"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_vocabulary_header"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:textColor="#FFFFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Nghĩa -->
                <TextView
                    android:id="@+id/tv_back_meaning_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="NGHĨA"
                    android:textColor="?colorPrimary"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_back_meaning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="4dp"
                    android:textColor="?colorOnBackground"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <!-- Ví dụ (ẩn nếu trống) -->
                <TextView
                    android:id="@+id/tv_back_example_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="VÍ DỤ"
                    android:textColor="?colorSecondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_back_example"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="3dp"
                    android:textColor="?colorOnBackground"
                    android:textSize="15sp"
                    android:fontStyle="italic"
                    android:visibility="gone" />

                <!-- Ghi chú (ẩn nếu trống) -->
                <TextView
                    android:id="@+id/tv_back_note_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="GHI CHÚ"
                    android:textColor="?colorTertiary"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_back_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="3dp"
                    android:textColor="?colorOnSurface"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <!-- Mastery level indicator -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_detail_section"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mức độ thuộc"
                        android:textColor="?colorOnSurface"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_back_mastery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?colorPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </FrameLayout>

    <!-- ===== HINT phía dưới thẻ ===== -->
    <LinearLayout
        android:id="@+id/layout_hint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/layout_action_buttons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card_front">

        <!-- Nút flip (hiện ở mặt trước, ẩn ở mặt sau) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_flip"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:paddingHorizontal="32dp"
            android:text="👁  Xem nghĩa"
            android:textAllCaps="false"
            android:textColor="#FFFFFFFF"
            android:textSize="16sp"
            app:backgroundTint="#FF4F46E5"
            app:cornerRadius="16dp"
            app:elevation="4dp" />
    </LinearLayout>

    <!-- ===== ACTION BUTTONS: Đã thuộc / Chưa thuộc (ẩn ở mặt trước) ===== -->
    <LinearLayout
        android:id="@+id/layout_action_buttons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="28dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_hint">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_forgot"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:text="😕  Chưa nhớ"
            android:textAllCaps="false"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            app:backgroundTint="#FFDC2626"
            app:cornerRadius="18dp"
            app:elevation="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_remembered"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:text="✅  Đã nhớ!"
            android:textAllCaps="false"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            app:backgroundTint="#FF16A34A"
            app:cornerRadius="18dp"
            app:elevation="4dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
