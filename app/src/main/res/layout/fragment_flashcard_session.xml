<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:orientation="vertical">

    <!-- ===== TOP BAR ===== -->
    <LinearLayout
        android:id="@+id/layout_topbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/btn_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_detail_section"
            android:gravity="center"
            android:text="✕"
            android:textColor="?colorOnBackground"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_progress_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="?colorOnBackground"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_score_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?colorOnSurface"
                    android:textSize="12sp" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progress_session"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="6dp"
                android:max="100"
                android:progressDrawable="@drawable/progress_vocabulary_mastery" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_total_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_vocabulary_stat"
            android:gravity="center"
            android:minWidth="52dp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!--
        ===== CARD CONTAINER =====
        Dùng FrameLayout với layout_weight=1 để tự động chiếm toàn bộ không gian
        giữa top bar và bottom controls. Cả 2 thẻ đều match_parent nên luôn cùng kích thước.
    -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="18dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp">

        <!-- ===== MẶT TRƯỚC: Từ + phiên âm ===== -->
        <FrameLayout
            android:id="@+id/card_front"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_vocabulary_header"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp">

                <!-- Label badge -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_vocabulary_stat"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:text="TỪ VỰNG"
                    android:letterSpacing="0.1"
                    android:textColor="#CCFFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <!-- Từ chính -->
                <TextView
                    android:id="@+id/tv_card_word"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:textColor="#FFFFFFFF"
                    android:textSize="48sp"
                    android:textStyle="bold" />

                <!-- Phiên âm -->
                <TextView
                    android:id="@+id/tv_card_phonetic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:textColor="#DFFFFFFF"
                    android:textSize="22sp" />

                <!-- Nguồn -->
                <TextView
                    android:id="@+id/tv_card_source"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:textColor="#88FFFFFF"
                    android:textSize="13sp" />

                <!-- Hint tap -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="48dp"
                    android:alpha="0.65"
                    android:gravity="center"
                    android:text="👆 Nhấn để xem nghĩa"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>
        </FrameLayout>

        <!-- ===== MẶT SAU: Nghĩa + Ví dụ + Ghi chú ===== -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/card_back"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_flashcard_card"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Header mặt sau: gradient với tên từ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_vocabulary_header"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="20dp">

                    <TextView
                        android:id="@+id/tv_back_word"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="#FFFFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:alpha="0.6"
                        android:text="👆 Nhấn thẻ để xem lại từ"
                        android:textColor="#FFFFFFFF"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Nội dung: nghĩa, ví dụ, ghi chú -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- NGHĨA -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.08"
                        android:text="NGHĨA"
                        android:textColor="?colorPrimary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_back_meaning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:lineSpacingExtra="4dp"
                        android:textColor="?colorOnBackground"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="#1A808080" />

                    <!-- VÍ DỤ (ẩn nếu trống) -->
                    <TextView
                        android:id="@+id/tv_back_example_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:letterSpacing="0.08"
                        android:text="VÍ DỤ"
                        android:textColor="?colorSecondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_back_example"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:lineSpacingExtra="3dp"
                        android:textColor="?colorOnBackground"
                        android:textSize="15sp"
                        android:fontStyle="italic"
                        android:visibility="gone" />

                    <!-- GHI CHÚ (ẩn nếu trống) -->
                    <TextView
                        android:id="@+id/tv_back_note_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:letterSpacing="0.08"
                        android:text="GHI CHÚ"
                        android:textColor="?colorTertiary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_back_note"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:lineSpacingExtra="3dp"
                        android:textColor="?colorOnSurface"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <!-- Mastery level indicator -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/bg_detail_section"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Mức độ thuộc"
                            android:textColor="?colorOnSurface"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tv_back_mastery"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="?colorPrimary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </FrameLayout>

    <!-- ===== BOTTOM CONTROLS ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="28dp">

        <!-- Nút "Xem nghĩa" — hiện ở mặt trước -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_flip"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:paddingHorizontal="36dp"
            android:text="👁  Xem nghĩa"
            android:textAllCaps="false"
            android:textColor="#FFFFFFFF"
            android:textSize="16sp"
            app:backgroundTint="#FF4F46E5"
            app:cornerRadius="16dp"
            app:elevation="4dp" />

        <!-- Nút Đã nhớ / Chưa nhớ — hiện ở mặt sau -->
        <LinearLayout
            android:id="@+id/layout_action_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_forgot"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:text="😕  Chưa nhớ"
                android:textAllCaps="false"
                android:textColor="#FFFFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="#FFDC2626"
                app:cornerRadius="18dp"
                app:elevation="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_remembered"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="✅  Đã nhớ!"
                android:textAllCaps="false"
                android:textColor="#FFFFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="#FF16A34A"
                app:cornerRadius="18dp"
                app:elevation="4dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
