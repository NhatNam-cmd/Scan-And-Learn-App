<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="620dp"
            android:paddingStart="24dp"
            android:paddingTop="36dp"
            android:paddingEnd="24dp"
            android:paddingBottom="28dp">

            <LinearLayout
                android:id="@+id/login_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <FrameLayout
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    android:background="@drawable/bg_login_brand_mark">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="A"
                        android:textColor="@android:color/white"
                        android:textSize="38sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tv_login_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:text="Scan And Learn"
                    android:textColor="?colorOnBackground"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_login_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:lineSpacingExtra="3dp"
                    android:text="Quét từ mới, luyện phát âm và đồng bộ tiến độ học bằng tài khoản Google của bạn."
                    android:textColor="#CC1F2937"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/login_panel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:background="@drawable/bg_login_panel"
                android:elevation="8dp"
                android:orientation="vertical"
                android:padding="22dp"
                app:layout_constraintBottom_toTopOf="@id/tv_login_footer"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/login_header"
                app:layout_constraintVertical_bias="0.35">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bắt đầu học thông minh hơn"
                    android:textColor="?colorOnSurface"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="3dp"
                    android:text="Một lần đăng nhập để lưu hồ sơ, cài đặt cá nhân và tiến độ ôn tập trên thiết bị của bạn."
                    android:textColor="#B31F2937"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_login_feature"
                        android:gravity="center"
                        android:minHeight="62dp"
                        android:padding="10dp"
                        android:text="Đồng bộ\nhồ sơ"
                        android:textColor="?colorSecondary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_login_feature"
                        android:gravity="center"
                        android:minHeight="62dp"
                        android:padding="10dp"
                        android:text="Lưu cài đặt\nTTS"
                        android:textColor="?colorSecondary"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_google_sign_in"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:text="Tiếp tục với Google"
                    android:textAllCaps="false"
                    android:textColor="?colorOnSurface"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="14dp"
                    app:icon="@drawable/ic_google_g"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:iconTint="@null"
                    app:strokeColor="#334F46E5"
                    app:strokeWidth="1dp" />

                <ProgressBar
                    android:id="@+id/progress_login"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_login_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_login_error"
                    android:lineSpacingExtra="2dp"
                    android:padding="12dp"
                    android:textColor="?colorError"
                    android:textSize="13sp"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_login_footer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:text="Bằng cách tiếp tục, bạn đồng ý sử dụng Google để xác thực tài khoản học tập."
                android:textColor="#991F2937"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</FrameLayout>
