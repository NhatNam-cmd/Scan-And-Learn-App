<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- ══════════════════════════════════
             HEADER BANNER
             ══════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_settings_header"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="24dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cài đặt"
                    android:textColor="#FFFFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Cá nhân hoá ứng dụng của bạn"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp" />

            </LinearLayout>

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:alpha="0.9"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="#FFFFFFFF" />

        </LinearLayout>

        <!-- ══════════════════════════════════
             SECTION: GIAO DIỆN
             ══════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="6dp"
            android:text="GIAO DIỆN"
            android:textColor="?colorPrimary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/bg_surface_panel"
            android:orientation="vertical">

            <!-- Chủ đề: Theo hệ thống -->
            <LinearLayout
                android:id="@+id/row_theme_system"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_settings_row_ripple"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_settings_icon"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_today"
                        app:tint="?colorOnPrimaryContainer" />
                </LinearLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:text="Theo hệ thống"
                    android:textColor="?colorOnSurface"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/rb_theme_system"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="false"
                    android:focusable="false" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginStart="70dp"
                android:background="#1A4F46E5" />

            <!-- Chủ đề: Sáng -->
            <LinearLayout
                android:id="@+id/row_theme_light"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_settings_row_ripple"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_settings_icon"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_gallery"
                        app:tint="?colorOnPrimaryContainer" />
                </LinearLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:text="Sáng"
                    android:textColor="?colorOnSurface"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/rb_theme_light"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="false"
                    android:focusable="false" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginStart="70dp"
                android:background="#1A4F46E5" />

            <!-- Chủ đề: Tối -->
            <LinearLayout
                android:id="@+id/row_theme_dark"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_settings_row_ripple"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_settings_icon"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_slideshow"
                        app:tint="?colorOnPrimaryContainer" />
                </LinearLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:text="Tối"
                    android:textColor="?colorOnSurface"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/rb_theme_dark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="false"
                    android:focusable="false" />

            </LinearLayout>


        </LinearLayout>

        <!-- ══════════════════════════════════
             SECTION: GIỌNG ĐỌC TTS
             ══════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="6dp"
            android:text="GIỌNG ĐỌC"
            android:textColor="?colorPrimary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12" />

        <!-- Tốc độ đọc card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_surface_panel"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_settings_icon_secondary"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_volume_up"
                        app:tint="?colorOnSecondaryContainer" />
                </LinearLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:text="Tốc độ đọc"
                    android:textColor="?colorOnSurface"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- Value badge -->
                <TextView
                    android:id="@+id/tv_speech_rate_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_settings_icon_secondary"
                    android:gravity="center"
                    android:minWidth="52dp"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textColor="?colorOnSecondaryContainer"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_speech_rate"
                style="@style/Widget.EnglishApp.Slider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:stepSize="0.1"
                android:valueFrom="0.5"
                android:valueTo="2.0" />

            <!-- Min / Max hints -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Chậm (0.5×)"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhanh (2.0×)"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="11sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Cao độ giọng đọc card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/bg_surface_panel"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_settings_icon_secondary"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_lock_silent_mode_off"
                        app:tint="?colorOnSecondaryContainer" />
                </LinearLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:text="Cao độ giọng đọc"
                    android:textColor="?colorOnSurface"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- Value badge -->
                <TextView
                    android:id="@+id/tv_speech_pitch_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_settings_icon_secondary"
                    android:gravity="center"
                    android:minWidth="52dp"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textColor="?colorOnSecondaryContainer"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_speech_pitch"
                style="@style/Widget.EnglishApp.Slider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:stepSize="0.1"
                android:valueFrom="0.5"
                android:valueTo="2.0" />

            <!-- Min / Max hints -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Trầm (0.5×)"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cao (2.0×)"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="11sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- ══════════════════════════════════
             SECTION: MỤC TIÊU HỌC
             ══════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="6dp"
            android:text="MỤC TIÊU HỌC"
            android:textColor="?colorPrimary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/bg_surface_panel"
            android:orientation="vertical"
            android:paddingBottom="8dp">

            <!-- Mục tiêu mỗi ngày -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_settings_icon_tertiary"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_agenda"
                        app:tint="?colorOnTertiaryContainer" />
                </LinearLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:text="Mục tiêu mỗi ngày"
                    android:textColor="?colorOnSurface"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- Value badge -->
                <TextView
                    android:id="@+id/tv_daily_goal_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_settings_icon_tertiary"
                    android:gravity="center"
                    android:minWidth="52dp"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textColor="?colorOnTertiaryContainer"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_daily_goal"
                style="@style/Widget.EnglishApp.Slider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:stepSize="1"
                android:valueFrom="1"
                android:valueTo="50" />

            <!-- Min / Max hints -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="1 từ"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="50 từ"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                android:background="#1A4F46E5" />

            <!-- Nhắc học hằng ngày (Switch row) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_settings_icon_tertiary"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_popup_reminder"
                        app:tint="?colorOnTertiaryContainer" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nhắc học hằng ngày"
                        android:textColor="?colorOnSurface"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:text="Nhận thông báo nhắc học theo lịch"
                        android:textColor="?android:textColorSecondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_reminder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginStart="70dp"
                android:layout_marginEnd="16dp"
                android:background="#1A4F46E5" />

            <!-- Giờ nhắc (Button row) -->
            <LinearLayout
                android:id="@+id/row_reminder_time"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_settings_row_ripple"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_settings_icon_tertiary"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_recent_history"
                        app:tint="?colorOnTertiaryContainer" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Thời gian nhắc"
                        android:textColor="?colorOnSurface"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tv_reminder_time_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:textColor="?colorPrimary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="?android:textColorSecondary" />

            </LinearLayout>

        </LinearLayout>

        <!-- ══════════════════════════════════
             SECTION: QUÉT TỪ
             ══════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="6dp"
            android:text="QUÉT TỪ"
            android:textColor="?colorPrimary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/bg_surface_panel"
            android:orientation="vertical">

            <!-- Tự động lưu từ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="64dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_settings_icon_secondary"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_save"
                        app:tint="?colorOnSecondaryContainer" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tự động lưu từ sau khi quét"
                        android:textColor="?colorOnSurface"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="Từ nhận diện được sẽ tự vào danh sách mà không cần xác nhận"
                        android:textColor="?android:textColorSecondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_auto_save_scan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- ══════════════════════════════════
             VỀ ỨNG DỤNG (bottom footer note)
             ══════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:text="Scan &amp; Learn • Phiên bản 1.0.0"
            android:textColor="?android:textColorSecondary"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
