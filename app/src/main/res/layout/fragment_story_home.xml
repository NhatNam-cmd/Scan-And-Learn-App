<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Hero icon with gradient circle background -->
        <FrameLayout
            android:id="@+id/layout_hero_icon"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="48dp"
            android:background="@drawable/bg_empty_state_circle">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="📖"
                android:textSize="52sp" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_story_intro_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Story Practice"
            android:textColor="?attr/colorOnBackground"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_story_intro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Chọn 5-10 từ chưa thuộc, ứng dụng sẽ tạo một câu chuyện ngắn. Nhiệm vụ của bạn là chạm vào từ đúng để điền vào từng ô trống."
            android:textColor="?attr/colorOnBackground"
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/layout_story_badges"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_story_badge"
                android:gravity="center"
                android:text="5-10 từ"
                android:textColor="?attr/colorOnSecondaryContainer"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_story_badge"
                android:gravity="center"
                android:text="✨ AI Story"
                android:textColor="?attr/colorOnSecondaryContainer"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_story_badge"
                android:gravity="center"
                android:text="+EXP"
                android:textColor="?attr/colorOnSecondaryContainer"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_create_story"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_story_button_primary"
            android:stateListAnimator="@null"
            android:text="✨ Tạo cốt truyện mới"
            android:textAllCaps="false"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_story_history"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_story_button_secondary"
            android:stateListAnimator="@null"
            android:text="📚 Xem lại story đã làm"
            android:textAllCaps="false"
            android:textColor="?attr/colorOnSurface"
            android:textSize="15sp" />
    </LinearLayout>
</ScrollView>
