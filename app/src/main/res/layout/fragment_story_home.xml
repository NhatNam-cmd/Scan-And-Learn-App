<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/light_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/img_story"
            android:layout_width="112dp"
            android:layout_height="112dp"
            android:layout_marginTop="48dp"
            android:contentDescription="Story"
            android:src="@android:drawable/ic_menu_edit"
            android:tint="@color/light_primary" />

        <TextView
            android:id="@+id/tv_story_intro_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Story Practice"
            android:textColor="@color/light_on_background"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_story_intro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Chọn 5-10 từ chưa thuộc, ứng dụng sẽ tạo một câu chuyện ngắn. Nhiệm vụ của bạn là chạm vào từ đúng để điền vào từng ô trống."
            android:textColor="@color/light_on_background"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_create_story"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="@color/light_primary"
            android:stateListAnimator="@null"
            android:text="Tạo cốt truyện mới"
            android:textAllCaps="false"
            android:textColor="@color/light_on_primary"
            android:textSize="16sp" />
    </LinearLayout>
</ScrollView>
