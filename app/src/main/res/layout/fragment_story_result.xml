<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingBottom="40dp">

        <!-- Score card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_story_header"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:paddingBottom="36dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆"
                android:textSize="56sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="Kết quả"
                android:textColor="#FFFFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_result_score"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textColor="#FFFFFFFF"
                android:textSize="36sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- EXP Badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_exp_badge"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ "
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tv_result_exp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnTertiaryContainer"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Motivational text -->
        <TextView
            android:id="@+id/tv_result_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Luyện tập thêm để ghi nhớ từ vựng tốt hơn nhé!"
            android:textColor="?attr/colorSecondary"
            android:textSize="15sp" />

        <!-- ===== Colored story review panel ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_panel_card"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Panel header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📝 Xem lại câu chuyện"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- Legend: green = correct, red = wrong -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="4dp"
                        android:background="#FF16A34A"
                        android:backgroundTint="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:text="Đúng"
                        android:textColor="@color/result_correct"
                        android:textSize="11sp" />

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="4dp"
                        android:background="#FFDC2626"
                        android:backgroundTint="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sai"
                        android:textColor="@color/result_wrong"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Colored story text -->
            <TextView
                android:id="@+id/tv_result_story"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingMultiplier="1.7"
                android:textColor="?attr/colorOnBackground"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

        <!-- Action buttons -->
        <Button
            android:id="@+id/btn_play_again"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_story_button_primary"
            android:stateListAnimator="@null"
            android:text="✨ Chơi lại"
            android:textAllCaps="false"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_story_home"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_story_button_secondary"
            android:stateListAnimator="@null"
            android:text="Quay lại trang chủ"
            android:textAllCaps="false"
            android:textColor="?attr/colorOnSurface"
            android:textSize="15sp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
