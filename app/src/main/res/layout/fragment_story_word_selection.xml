<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_background"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_word_selection_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chọn từ vựng"
        android:textColor="@color/light_on_background"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_selection_counter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="0/10 từ đã chọn"
        android:textColor="@color/light_secondary"
        android:textSize="14sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_words"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="12dp" />

    <TextView
        android:id="@+id/tv_empty_words"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:padding="24dp"
        android:text="Chưa có từ vựng chưa thuộc.\nHãy thêm từ mới hoặc quét từ trước khi tạo truyện."
        android:textColor="@color/light_on_background"
        android:textSize="16sp"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/progress_story_generation"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone" />

    <Button
        android:id="@+id/btn_start_story"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="@color/light_primary"
        android:enabled="false"
        android:alpha="0.45"
        android:text="Chọn ít nhất 5 từ"
        android:textAllCaps="false"
        android:textColor="@color/light_on_primary" />
</LinearLayout>
