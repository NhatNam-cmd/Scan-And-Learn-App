                ", sourceType='" + sourceType + '\'' +
                ", masteryLevel=" + masteryLevel +
                ", isMastered=" + isMastered +
                ", nextReviewDate=" + nextReviewDate +
                ", createdAt=" + createdAt +
                ", updatedAt=" + updatedAt +
                '}';
    }
}
